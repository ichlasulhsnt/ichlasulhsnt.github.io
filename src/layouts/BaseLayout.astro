---
// Learn about using Astro layouts:
// https://docs.astro.build/en/core-concepts/layouts/

// Component Imports
import MainHead from "../components/MainHead.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string | undefined;
  description?: string | undefined;
}

const { title, description } = Astro.props;

declare global {
  interface Window {
    dataLayer: any[];
  }
}
---

<html lang="en">
  <head>
    <MainHead title={title} description={description} />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-B1HGX0R9YB"
    ></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        // @ts-ignore
        dataLayer.push(arguments);
      }
      // @ts-ignore
      gtag("js", new Date());

      // @ts-ignore
      gtag("config", "G-B1HGX0R9YB");
    </script>
  </head>
  <body>
    <div class="stack backgrounds">
      <Nav />
      <slot />
      <Footer />
    </div>

    <script>
      // Add “loaded” class once the document has completely loaded.
      addEventListener("load", () =>
        document.documentElement.classList.add("loaded")
      );
    </script>

    <style>
      :root {
        --bg-glow-top: hsla(185, 90%, 80%, 0.30);
        --bg-glow-bottom: hsla(210, 60%, 88%, 0.14);
      }

      :root.theme-dark {
        --bg-glow-top: hsla(225, 72%, 14%, 1);
        --bg-glow-bottom: hsla(234, 55%, 8%, 0.9);
      }

      .backgrounds {
        min-height: 100%;
        isolation: isolate;
        background:
          /* noise texture */
          url("/assets/backgrounds/noise.png") top center/220px repeat,
          /* top accent glow — covers hero area */
          radial-gradient(ellipse 150% 55% at 50% -5%, var(--bg-glow-top), transparent 70%),
          /* bottom warmth */
          radial-gradient(ellipse 120% 40% at 50% 108%, var(--bg-glow-bottom), transparent 70%),
          /* base color */
          var(--gray-999);
        background-blend-mode: overlay, normal, normal, normal;
      }

      @media (forced-colors: active) {
        .backgrounds {
          background: none;
          background-blend-mode: none;
        }
      }
    </style>
  </body>
</html>
