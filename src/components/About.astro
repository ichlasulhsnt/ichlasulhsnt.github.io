---
import Hero from "../components/Hero.astro";
---

<div class="stack gap-20">
  <header class="wrapper hero">
    <Hero align="center" title="About Me" tagline="Get to know me"/>
    
    <main class="about">
      <section>
        <h2 class="section-title">Background</h2>
        <div class="content">
          <p>
            Hi there! I'm Ichlas, a fresh graduate in computer science
            who have good interpersonal skills, an excellent team worker, and
            very willing to learn and develop new skills. I am reliable and
            dependable and often seek new responsibilities within a wide range
            of employment areas. I have an active and dynamic approach to work
            and getting things done efficiently and precisely.
          </p>
          <p>
            I am interested in all fields related to data, especially data
            analysis, data science, and machine learning.
            Besides programming, I also love doing sports such as running and
            playing tennis.
          </p>
        </div>
      </section>
      <section>
        <h2 class="section-title">Education</h2>
        <div class="content">
          <div class="edu-entry">
            <div class="edu-header">
              <div>
                <b>Sepuluh Nopember Institute of Technology</b>
                <span class="location"> - Surabaya, Indonesia</span>
              </div>
              <span class="edu-date">2020 – 2024</span>
            </div>
            <span class="degree">Bachelor Degree in Computer Science</span>
          </div>
          <div class="edu-entry">
            <div class="edu-header">
              <div>
                <b>SMAN 70 Jakarta</b>
                <span class="location"> - Jakarta, Indonesia</span>
              </div>
              <span class="edu-date">2017 – 2020</span>
            </div>
            <span class="degree">Science Major</span>
          </div>
        </div>
      </section>
      <section>
        <h2 class="section-title">Skills</h2>
        <div class="content">
          <div class="skills-grid">
            <div class="skill-item">
              <img class="skill-icon" alt="Python" title="Python" src="/assets/skills/python.png" />
              <span class="skill-label">Python</span>
            </div>
            <div class="skill-item">
              <img class="skill-icon" alt="TensorFlow" title="TensorFlow" src="/assets/skills/tensorflow.png" />
              <span class="skill-label">TensorFlow</span>
            </div>
            <div class="skill-item">
              <img class="skill-icon" alt="Google Colab" title="Google Colab" src="/assets/skills/colab.png" />
              <span class="skill-label">Colab</span>
            </div>
            <div class="skill-item">
              <img class="skill-icon" alt="JavaScript" title="JavaScript" src="/assets/skills/javascript.png" />
              <span class="skill-label">JavaScript</span>
            </div>
            <div class="skill-item">
              <img class="skill-icon" alt="Astro" title="Astro" src="/assets/skills/astro.png" />
              <span class="skill-label">Astro</span>
            </div>
            <div class="skill-item">
              <img class="skill-icon" alt="Laravel" title="Laravel" src="/assets/skills/laravel.png" />
              <span class="skill-label">Laravel</span>
            </div>
            <div class="skill-item">
              <img class="skill-icon" alt="MySQL" title="MySQL" src="/assets/skills/mysql.png" />
              <span class="skill-label">MySQL</span>
            </div>
            <div class="skill-item">
              <img class="skill-icon" alt="Microsoft Office" title="Microsoft Office" src="/assets/skills/office.png" />
              <span class="skill-label">Office</span>
            </div>
            <div class="skill-item">
              <img class="skill-icon" alt="Tableau" title="Tableau" src="/assets/skills/tableau.png" />
              <span class="skill-label">Tableau</span>
            </div>
            <div class="skill-item">
              <img class="skill-icon" alt="TypeScript" title="TypeScript" src="/assets/skills/typescript.png" />
              <span class="skill-label">TypeScript</span>
            </div>
            <div class="skill-item">
              <img class="skill-icon" alt="Figma" title="Figma" src="/assets/skills/figma.png" />
              <span class="skill-label">Figma</span>
            </div>
          </div>
        </div>
      </section>
      <section>
        <h2 class="section-title">Organizational Experience</h2>
        <div class="content">
          <div class="org-entry">
            <div class="org-header">
              <div>
                <b>Ramadhan Committee 2025</b>
                <span class="location"> – Banten, Indonesia</span>
              </div>
              <span class="edu-date">Feb 2025 – Apr 2025</span>
            </div>
            <span class="degree">Head Event</span>
            <ul class="org-list">
              <li>
                Oversaw the entire event, presented daily financial reports during Tarawih, designed promotional
                materials using Canva, and coordinated the distribution of donation boxes to over 150 recipients,
                along with venue preparation for the Eid al-Fitr prayer.
              </li>
            </ul>
          </div>
          <div class="org-entry">
            <div class="org-header">
              <div>
                <b>Schematics ITS 2022</b>
                <span class="location"> – Surabaya, Indonesia</span>
              </div>
              <span class="edu-date">Mar 2022 – Nov 2022</span>
            </div>
            <span class="degree">3DC Expert Staff (Content Creator)</span>
            <ul class="org-list">
              <li>
                Led a team of video designer staffs, designed and edited social media contents using Adobe After
                Effects and Adobe Premiere Pro for Schematics Instagram posts and YouTube channel.
              </li>
            </ul>
          </div>
        </div>
      </section>
    </main>
  </header>
</div>

<style lang="scss">
  .hero {
    display:flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }

  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    justify-content: center;
  }

  .skill-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }

  .skill-icon {
    width: 48px;
    height: 48px;
    object-fit: contain;
  }

  .skill-label {
    font-size: var(--text-sm);
    color: var(--gray-400);
    text-align: center;
  }

  .edu-entry {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;

    &:not(:last-child) {
      margin-bottom: 1rem;
    }
  }

  .edu-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .org-entry {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;

    &:not(:last-child) {
      margin-bottom: 1.25rem;
    }
  }

  .org-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .org-list {
    list-style-type: circle;
    padding-left: 1.5rem;
    margin-top: 0.35rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .edu-date {
    color: var(--gray-400);
    font-size: var(--text-sm);
    white-space: nowrap;
  }

  .location {
    color: var(--gray-400);
  }

  .degree {
    font-style: italic;
    color: var(--gray-300);
  }

  .about {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    color: var(--gray-200);

    .link {
      justify-self: center;
      align-self: center;
      grid-column: 1 / -1;
    }
  }

  .section-title {
    text-align: center;
    grid-column: 1 / 4;
    grid-column-start: 1;
    font-size: var(--text-2xl);
    color: var(--gray-0);
  }

  .content {
    text-align: justify;
    grid-column: 1 / 4;

    p:not(:last-child) {
      margin-bottom: 1rem;
    }
  }

  @media (min-width: 70em) {
    .hero {
      flex-direction: row;
      gap: 6rem;
    }

    .icon {
      flex-direction: row;
    }

    .about {
      display: grid;
      grid-template-columns: 1fr 60% 1fr;
    }

    section {
      display: contents;
      font-size: var(--text-lg);
    }
  }
</style>
