---
import Hero from "../components/Hero.astro";
---
<div class="stack gap-20">
  <header class="wrapper hero">
    <Hero align="center" title="Past Experience" tagline="My Profesional Track Record" />
    <!-- <img
      alt="illustration of profile page"
      src="/assets/illustrations/about.svg"
    /> -->
  </header>

  <main class="wrapper about">
    <section>
      <div class="section-title">
        <a href="https://jexa.co.id/" class="rounded-image">
          <img

            alt="jexa logo"
            style="margin-top: 5px; padding: 30px; border-radius: 0rem;"
            src="/assets/experience/jexa.png"
          />
        </a>
      </div>
      <div class="content">
        <div class="job-header">
          <b class="job-title">Software Engineer Freelance</b>
          <span class="job-date">Aug 2025 – Present</span>
        </div>
        <div class="company-line">
          <span class="company-name">JEXA IT Consulting</span>
          <span class="location"> – Jakarta, Indonesia</span>
        </div>
        <p class="company-desc">
          An IT consulting firm providing software and digital solutions to businesses across various sectors.
        </p>
        <ul class="bullet-list">
          <li>
            Developed a mosque dashboard application in Android Studio to manage and display Adzan and Iqomah
            announcements, utilizing Supabase as a local database server for real-time updates and data storage.
          </li>
          <li>
            Collaborated with a team to develop an e-commerce website for a growing bookstore using React and
            MedusaJS: composed initial project proposal and system designs, designed the user interface in Figma
            based on client requirements and implemented the design into a responsive frontend, and developed a
            TypeScript script to automatically convert data from the old system to the newly developed one.
          </li>
        </ul>
      </div>
    </section>
    <section>
      <div class="section-title">
        <a href="https://maknadata.ai/" class="rounded-image">
          <img

            alt="maknadata logo"
            style="margin-top: 5px; padding: 40px; border-radius: 0rem;"
            src="/assets/experience/maknadata.png"
          />
        </a>
      </div>
      <div class="content">
        <div class="job-header">
          <b class="job-title">AI Product Data Analyst</b>
          <span class="job-date">Jun 2025 – Dec 2025</span>
        </div>
        <div class="company-line">
          <span class="company-name">Maknadata</span>
          <span class="location"> – Jakarta, Indonesia</span>
        </div>
        <p class="company-desc">
          A data and AI solutions company focused on delivering AI-powered products across various industries in Indonesia.
        </p>
        <ul class="bullet-list">
          <li>
            Ensured chatbot quality for a sports retail company by identifying unseen bugs, suggesting improvements,
            and testing more than 40 user scenarios with multiple variations using Asana as the main governance tool.
          </li>
          <li>
            Evaluated an AI-powered audio summarizer for a government project &amp; contributed in a nationwide GTM
            workshop involving 90+ cities.
          </li>
          <li>
            Developed internal compliance documentation covering information security and business continuity,
            created an awareness presentation, and achieved a &gt;95% employee understanding rate.
          </li>
          <li>
            Supported an AI-driven customer service project for a lending company by reviewing 150+ tickets,
            creating 50+ scenario permutations, analyzing 40K+ ticket records, and drafting MoMs from weekly
            syncs and other important meetings.
          </li>
        </ul>
      </div>
    </section>
    <section>
      <div class="section-title">
        <a href="https://www.ey.com/en_id" class="rounded-image">
          <img

            alt="ey logo"
            style="margin-top: 5px; padding: 30px; border-radius: 0rem;"
            src="/assets/experience/ey.png"
          />
        </a>
      </div>
      <div class="content">
        <div class="job-header">
          <b class="job-title">Technical Consultant: Data & Analytics</b>
          <span class="job-date">Dec 2023 – Feb 2024</span>
        </div>
        <div class="company-line">
          <span class="company-name">Ernst &amp; Young Indonesia</span>
          <span class="location"> – Jakarta, Indonesia</span>
        </div>
        <p class="company-desc">
          One of the largest professional services networks in the world that operates
          as a network of member firms which are structured as separate legal entities in a partnership.
        </p>
        <p>
          Worked for one of the biggest multinational automotive companies in Southeast Asia as a PMO,
          managing 4 different workstreams with 20+ sub-workstreams and 80+ EY workers from Indonesia,
          India, and Singapore:
        </p>
        <ul class="bullet-list">
          <li>
            Utilized Microsoft Office to draft MoMs for workstream meetings, oversee project infrastructures,
            develop slide decks for key meetings including steering committees, and assisted in preparing
            FSD &amp; TSD documents.
          </li>
          <li>
            Maintained project governance using Notion Project, encompassing meetings, risks, actions, and
            timelines across all workstreams for 20+ deliverables over a 6-month period.
          </li>
        </ul>
      </div>
    </section>
    <section>
      <div class="section-title">
        <a href="https://nusantararegas.com/">
          <img
            class="rounded-image"
            alt="nr logo"
            src="/assets/experience/nr.png"
          />
        </a>
      </div>
      <div class="content">
        <div class="job-header">
          <b class="job-title">Information System Intern</b>
          <span class="job-date">Sep 2023 – Dec 2023</span>
        </div>
        <div class="company-line">
          <span class="company-name">PT Nusantara Regas</span>
          <span class="location"> – Jakarta, Indonesia</span>
        </div>
        <p class="company-desc">
          A subsidiary of Pertamina Gas Negara that does business in the storage and regasification of liquefied natural gas over the sea.
        </p>
        <ul class="bullet-list">
          <li>
            Developed and enhanced internal web applications based on user requirements, including managing
            and integrating API endpoints to synchronize internal data using .NET and Laravel.
          </li>
          <li>
            Administered and configured 50+ user devices, including MAC address registration to Cisco Wireless
            LAN Controller (WLC), DNS configuration, IP printer setup, disk partitioning, and BitLocker encryption,
            while automating essential software installations using PowerShell scripts, reducing manual setup time
            by approximately 40–50% per device.
          </li>
          <li>
            Provided day-to-day IT support by troubleshooting hardware, software, and network issues, achieving
            an estimated &gt;90% first-level issue resolution rate.
          </li>
        </ul>
      </div>
    </section>
    <section>
      <div class="section-title">
        <a href="https://grow.google/intl/id_id/bangkit/?tab=machine-learning">
          <img
            class="rounded-image"
            alt="bangkit logo"
            style="padding: 10px"
            src="/assets/experience/bangkit.png"
          />
        </a>
      </div>
      <div class="content">
        <div class="job-header">
          <b class="job-title">Machine Learning Cohort</b>
          <span class="job-date">Feb 2023 – Jul 2023</span>
        </div>
        <div class="company-line">
          <span class="company-name">Bangkit Academy 2023 by Google, GoTo, and Traveloka</span>
          <span class="location"> – Bandung, Indonesia</span>
        </div>
        <p class="company-desc">
          A career readiness program initiated by Google, GoTo, Tokopedia, and Traveloka, with the aim of shaping high-quality technical talent in Indonesia. This program offers a variety of learning paths, including Machine Learning, Cloud Computing, and Android Developer path.
        </p>
        <ul class="bullet-list">
          <li>Learned the basics of data analytics, machine learning, and deep learning.</li>
          <li>Learned soft skills like growth mindset, critical thinking, time management, and English for business with a native speaker.</li>
          <li>Earned the TensorFlow Developer Certificate, covering foundational &amp; practical machine learning skills using TensorFlow.</li>
          <li>Achieved an average score of 88.2/100 from 10 main course subjects including capstone project.</li>
        </ul>
      </div>
    </section>
  </main>
</div>

<style lang="scss">
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    // padding-inline: 2.5rem;
    gap: 1.5rem;

    img {
      width: 100%;
      max-width: 22rem;
    }
  }

  .about {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  .rounded-image {
      object-fit: contain;
      margin-top: 15px;
      width: 200px;
      height: 200px;

      display: block;
      text-decoration: none;
      background: var(--gradient-subtle);
      border: 2.5px solid var(--accent-regular);
      box-shadow: var(--shadow-sm);
      border-radius: 3rem;
      transition: var(--theme-transition);

      &:hover {
        box-shadow: var(--shadow-md);
        border: 2.5px solid var(--accent-dark);
        filter: brightness(1.1);
        transform: translateY(-0.5rem);
      }
  }

  .logo-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;

    span {
      font-size: var(--text-xl);
      font-weight: 700;
      color: var(--accent-regular);
      letter-spacing: 0.05em;
    }
  }

  section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    color: var(--gray-0);

    .link {
      justify-self: center;
      align-self: center;
      grid-column: 1 / -1;
    }
  }

  .section-title {
    text-align: center; /* Center-align the text and image */
    display: flex; /* Enables flexbox for better layout control */
    flex-direction: column; /* Stacks text and image vertically */
    align-items: center; /* Centers items horizontally */
    gap: 1rem; /* Adds spacing between the text and image */
  }

  .content {
    grid-column: 2 / 4;
    text-align: justify;

    p:not(:last-child) {
      margin-bottom: 0.75rem;
    }
  }

  .job-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-bottom: 0.25rem;
  }

  .job-title {
    font-size: var(--text-lg);
  }

  .job-date {
    font-size: var(--text-sm);
    color: var(--gray-400);
    white-space: nowrap;
  }

  .company-line {
    margin-bottom: 0.5rem;
  }

  .company-name {
    font-style: italic;
    font-size: var(--text-md);
  }

  .location {
    color: var(--gray-400);
    font-size: var(--text-md);
  }

  .company-desc {
    font-size: var(--text-base);
    color: var(--gray-400);
    margin-bottom: 0.75rem;
  }

  .bullet-list {
    list-style-type: circle;
    padding-left: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  @media (min-width: 50em) {
    .hero {
      flex-direction: row;
      gap: 6rem;
    }

    .about {
      display: grid;
      grid-template-columns: 0.5fr 40% 1fr;
    }

    section {
      display: contents;
      font-size: var(--text-lg);
    }

    .job-title {
      font-size: var(--text-xl);
    }
  }
</style>
